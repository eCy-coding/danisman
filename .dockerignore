# ─── EcyPro Docker Build Context Allowlist ───────────────
# Everything listed here is EXCLUDED from the image build context.
# Goal: minimal context (< 50 MB) → fast builds, no secrets leak.

# Dependencies (installed inside the image)
node_modules
pnpm-store
.pnpm
.yarn
yarn.lock
pnpm-lock.yaml

# Build outputs (regenerated by Dockerfile)
dist
build
out
.vite
stats.html

# VCS / CI / editor metadata
.git
.gitignore
.github
.gitlab
.husky
.vscode
.idea
*.iml

# Test artefacts
coverage
.nyc_output
playwright-report
test-results
e2e
vitest.config.ts
playwright.config.ts
src/test
src/setupTests.ts
src/vitest-setup.ts
**/*.spec.ts
**/*.spec.tsx
**/*.test.ts
**/*.test.tsx

# Logs + debug + ad-hoc artefacts
*.log
logs/
build_log*.txt
e2e_output*.txt
e2e_full_run.log
e2e_initial_run.log
audit_fail_log.txt
assessment_debug.txt
case_studies_debug.txt
debug_dump.txt
test_debug.log
server.log
typecheck.log
lint_output.txt
lint_results.txt
crawler_report.txt
diagnostic-screenshot.png
terminal-debug.png
eslint-report.json
lighthouse-report.json

# Local databases / caches / profiles
dev.db
browser-profile
dumps
*.sqlite
.eslintcache
.turbo
.cache

# Env files — NEVER ship secrets in an image
.env
.env.*
!.env.example
!.env.deploy.example

# Large non-runtime blobs
*.zip
ecypro-theme.zip
microweber.zip

# Docs + misc noise
README.md
HOSTINGER_GUIDE.md
docs
brain
prompts
task.md
*.md

# Claude Code (geliştirici aracı — image'a sızdırılmaz)
.claude
CLAUDE.md
.windsurf
scripts/install-claude-code.sh
scripts/claude-doctor.sh

# Dockerfile + compose themselves don't need to be in the context
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore
