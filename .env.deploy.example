# Hostinger SSH/RSYNC Configuration
# COPY THIS FILE TO .env.deploy AND FILL IN THE DETAILS
# DO NOT COMMIT .env.deploy TO GIT

# The IP Address or Domain of your Hostinger server (found in Dashboard -> SSH Access)
HOSTINGER_HOST=123.123.123.123

# Your SSH Username (found in SSH Access)
HOSTINGER_USER=u123456789

# The path to your public_html folder
# IMPORTANT: Be very careful with this path. rsync --delete will wipe anything else!
# usually: /home/u123456789/domains/yourdomain.com/public_html
HOSTINGER_PATH=/home/u123456789/domains/yourdomain.com/public_html
