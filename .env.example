# ─── EcyPro Environment Variables ─────────────────────
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ecypro?schema=public"

# P20 — Optional read replica (Standard+ Render PG only)
# Reads are routed here when set; writes always go to primary.
# DATABASE_URL_REPLICA="postgresql://user:password@replica.example:5432/ecypro?schema=public"

# P20 — Connection pool tuning (mathematical sizing per Render tier)
# Formula: pool = (cpu_cores × 2) + 1 spindle (SSD)
# Starter (0.5 vCPU): 5-10 | Standard (1 vCPU): 15 | Pro (2 vCPU): 30
PG_POOL_MAX=10
PG_POOL_MIN=0
PG_POOL_IDLE_MS=30000
PG_POOL_CONN_MS=30000
PG_POOL_QUERY_MS=10000
PG_STATEMENT_MS=15000

# P20 — Node heap ceiling (V8 default 1.5 GB; cap to fit the instance)
# Starter 512 MB -> 384  |  Standard 2 GB -> 1536  |  Pro 4 GB -> 3072
# NODE_OPTIONS=--max-old-space-size=384

# P20 — Cache warm-up (post-deploy hook)
# Bearer token authorizing POST /admin/cache/warmup; min 16 chars.
# CACHE_WARMUP_TOKEN=
# CACHE_WARMUP_BASE_URL=https://api.ecypro.com

# JWT
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Redis (optional — falls back to in-memory if unavailable)
REDIS_URL="redis://localhost:6379"

# Logging
LOG_LEVEL="info"

# Frontend (Vite)
VITE_API_URL="http://localhost:3001/api"

# Email (EmailJS)
VITE_EMAILJS_SERVICE_ID=""
VITE_EMAILJS_TEMPLATE_ID=""
VITE_EMAILJS_PUBLIC_KEY=""

# Analytics (optional)
VITE_GA_TRACKING_ID=""

# P97 — PostHog (KVKK strict opt-in). EU host keeps data inside EEA.
# Leave VITE_POSTHOG_KEY empty in dev to disable; ConsentBanner gates capture
# until the user explicitly accepts. Production key lives in Vercel ENV
# (project: ecypro, scope: Production+Preview); do not commit the value here.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://eu.posthog.com"

# Google Tag Manager — production container GTM-NH7RJ9FB hard-wired in
# index.html. GA4 measurement ID G-3Q4T3KL83V is mapped inside the GTM
# workspace (Tags → GA4 Configuration → Measurement ID), not via env.
VITE_GTM_CONTAINER_ID="GTM-NH7RJ9FB"

# Error Reporting (optional)
VITE_SENTRY_DSN=""
SENTRY_DSN=""

# Sentry CI — Source Maps Upload (P40-T91)
# Setup: sentry.io → Settings → Auth Tokens → Create token (project:releases scope)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="ecypro"
SENTRY_PROJECT="ecypro-frontend"

# Live Chat (optional — leave VITE_LIVECHAT_PROVIDER blank to disable)
# Provider must be one of: crisp | tawk | intercom
VITE_LIVECHAT_PROVIDER=""
VITE_LIVECHAT_ID=""
# tawk.to also requires a widget id
VITE_LIVECHAT_TAWK_WIDGET_ID=""

# Trust Proxy — number of hops or true/false (Express)
TRUST_PROXY="1"

# Deployment
VERCEL_TOKEN=""
RENDER_API_KEY=""

# Claude Code (opsiyonel — OAuth login alternatifi)
# `claude` CLI ilk kullanımda interaktif login akışı sunar.
# Headless / CI ortamları için API key tercih edilir.
# Anahtar oluşturma: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Ollama (Local AI Inference — optional)
# Apple Silicon 48GB ile qwen2.5-coder:32b önerilen model
# Başlatmak için: npm run ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="qwen2.5-coder:14b"
OLLAMA_TEMPERATURE=0.2

# Vite Frontend Ollama erişimi
VITE_OLLAMA_BASE_URL="http://localhost:11434"
VITE_OLLAMA_DEFAULT_MODEL="qwen2.5-coder:14b"
VITE_OLLAMA_TEMPERATURE=0.2

# ─── SEO & Indexing (Phase 31) ────────────────────────────────────────────────
# Google Search Console — production canonical base URL
VITE_PROD_URL="https://www.ecypro.com"

# Google Indexing API — service account JSON key path (gitignored)
# Setup: Cloud Console → Indexing API → Service Account → JSON key
# Then: Add service account email as GSC Property "Owner"
GOOGLE_INDEXING_KEY_PATH="./secrets/indexing-key.json"

# IndexNow — Bing/Yandex bulk push key
# Setup: openssl rand -hex 16 → add here + create public/<key>.txt
INDEXNOW_KEY=""

# Microsoft Clarity — free heatmap + session recording (P34-T05)
# Setup: clarity.microsoft.com → Create project → copy Project ID
VITE_CLARITY_PROJECT_ID=""

# ─── Booking & Email (Phase 37) ───────────────────────────────────────────────
# Resend.com — transactional email (100/day free, 3K/month)
# Setup: resend.com → Create API key → copy here
RESEND_API_KEY=""
EMAIL_FROM="EcyPro <noreply@ecypro.com>"
EMAIL_FROM_ADDRESS="noreply@ecypro.com"

# HMAC secret for manage tokens (reschedule/cancel email links)
# Generate: openssl rand -hex 32
BOOKING_HMAC_SECRET=""

# Cal.com API key (P37-T01) — required for real slot availability
# Setup: cal.com → Settings → Developer → API Keys → Create
CAL_COM_API_KEY=""

# Cal.com event type ID (numeric) — find in your cal.com event type URL
# e.g. cal.com/emre/30min → Settings → copy ID from URL
CAL_COM_EVENT_TYPE_ID=""

# Cal.com username (e.g. "emre" from cal.com/emre)
CAL_COM_USERNAME=""

# Cal.com webhook secret (P37-T08)
# Setup: cal.com → Settings → Webhooks → Add webhook → copy secret
CAL_COM_WEBHOOK_SECRET=""

# ─── Calendly (Track B — Lead Capture, 26 May launch) ─────────────────────────
# Calendly scheduling URL — exposed to the browser via VITE_ prefix.
# Empty value → CalendlyEmbed falls back to the native inline-form path and
# Hero / Pricing / Discovery CTAs route to the in-app `/discovery-call` page.
# Placeholder shipped for launch; replace with the real account URL on Vercel.
VITE_CALENDLY_URL="https://calendly.com/ecypro/discovery"

# Calendly webhook signing key — verifies POST /api/v1/calendly payloads.
# Generate via the Calendly Webhook Subscription API; store server-side only.
CALENDLY_WEBHOOK_SIGNING_KEY=""

# PostHog (server-side event ingestion — calendly_booked, contact_submit,
# quick_check_completed, pricing_calculator_completed).
# Empty key → events become no-ops; browser analytics keep working via VITE_*.
POSTHOG_API_KEY=""
POSTHOG_HOST="https://eu.i.posthog.com"
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://eu.i.posthog.com"

# Notion CRM (Track 1 launch) — Prospect upsert + Interaction append.
# Create an integration: notion.so/my-integrations → New integration.
# Share the Prospects + Interactions databases with the integration
# (Database … → Add connections). Copy the database IDs from the URL
# segment between the last `/` and the `?` query string.
# When NOTION_API_KEY is empty every CRM write is a silent no-op so
# preview + CI environments don't depend on outbound HTTP.
NOTION_API_KEY=""
NOTION_DB_PROSPECTS=""
NOTION_DB_INTERACTIONS=""
# Optional — reserved for future Engagement + Deliverable rollups; the
# launch routes do not write to these databases yet, but Vercel ENV
# should carry the IDs so backfills are one config flip away.
NOTION_ENGAGEMENTS_DB_ID=""
NOTION_DELIVERABLES_DB_ID=""

# Track 1 launch — founder inbox used as Reply-To on every outbound
# Resend email so the conversation continues out of the noreply mailbox.
FOUNDER_EMAIL="hello@ecypro.com"

# ─── Better Stack (Logtail) — Centralized Log Aggregation (P40-T03) ──────────
# Setup: betterstack.com → Logs → Create source → copy Source Token
LOGTAIL_SOURCE_TOKEN=""

# ─── 2FA / TOTP (P35-T04) ────────────────────────────────────────────────────
# No configuration needed — secrets stored per-user in DB
# Optional: Encryption key for totpSecret at-rest encryption (Render: use disk encryption)
TOTP_ENCRYPTION_KEY=""

# ─── GrowthBook A/B Testing (P34-T04) ────────────────────────────────────────
# Setup: growthbook.io → Create project → SDK Connection → copy Client Key
# Self-hosted: https://github.com/growthbook/growthbook (Docker)
VITE_GROWTHBOOK_CLIENT_KEY=""
VITE_GROWTHBOOK_API_HOST="https://cdn.growthbook.io"

# ═══════════════════════════════════════════════════════════════════════════
# 15-Pane Orchestrator (istek5) — opsiyonel watcher servisleri için
# ═══════════════════════════════════════════════════════════════════════════

# ─── Telegram (CRM-Watch + Sec-Watch + Deploy-Watch + Lead Pipeline) ────────
# Bot oluştur: @BotFather → /newbot → token al
# Chat ID: bota /start at, https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Track 1 launch — optional founder-only chat for booking pings. When set,
# Calendly + Quick-Check + Pricing-Calc alerts can be routed to a separate
# chat instead of the shared ops channel. Reads via process.env in route
# handlers if you wire a custom Telegram dispatcher.
TELEGRAM_FOUNDER_CHAT_ID=""

# ─── MaxMind GeoIP (Geo-Watch) ───────────────────────────────────────────────
# Ücretsiz hesap: maxmind.com → Account → License Keys → Create
# Olmadan da çalışır: Cloudflare CF-IPCountry header fallback aktif
MAXMIND_LICENSE_KEY=""

# ─── Vercel Deploy Watcher ──────────────────────────────────────────────────
# vercel.com/account/tokens → Create token (full-access önerilir)
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""

# ─── Render Deploy Watcher ──────────────────────────────────────────────────
# dashboard.render.com → Account Settings → API Keys → Create
RENDER_API_KEY=""
RENDER_SERVICE_ID=""

# ─── Mailpit Dev SMTP (docker-compose.dev.yml) ──────────────────────────────
# Geliştirmede gerçek email yerine local Mailpit kullan (UI: http://localhost:8025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
EMAIL_FROM="dev@ecypro.local"

# ─── Analytics Dev Server (Analytics-Dev) ───────────────────────────────────
# Mock GA4 relay portu — frontend bu adrese push'lar
ANALYTICS_DEV_PORT="4001"

# ─── LHCI Watcher Hedef URL ─────────────────────────────────────────────────
LHCI_PREVIEW_URL="http://localhost:4173"

# ─── CRM Watcher (admin token, opsiyonel) ───────────────────────────────────
# CRM-Watch daemon'ı admin endpoint'e erişmek için kullanır
ADMIN_TOKEN=""
API_BASE_URL="http://localhost:3001/api"

# ─── Admin Seed (backend — run once after db:push) ───────────────────────────
# Usage: SEED_ADMIN_EMAIL=admin@ecypro.com SEED_ADMIN_PASSWORD='...' npm run db:seed
# SEED_ADMIN_PASSWORD is required — seed skips admin upsert if missing
SEED_ADMIN_EMAIL="admin@ecypro.com"
SEED_ADMIN_PASSWORD=""

# ─── P55 Drip Campaign Worker ───────────────────────────────────────────────
# Set to "1" to enable the 60s-tick drip campaign worker.
# When unset/0: enrollSubscriber() no-ops; cron does not start.
DRIP_CAMPAIGN_ENABLED="0"

# ─── P55 Newsletter Lifecycle (HMAC tokens) ─────────────────────────────────
# Used to sign confirm + unsubscribe tokens (no DB schema migration needed).
# Must be 32+ chars; rotate quarterly. WITHOUT this env, /confirm/:token and
# /unsubscribe/:token always redirect to /newsletter/invalid-token.
NEWSLETTER_HMAC_SECRET=""
APP_URL="https://www.ecypro.com"

# ─── P55 SMTP (drip campaign delivery) ──────────────────────────────────────
# nodemailer transport; falls back to no-op if any of these is unset.
SMTP_FROM="EcyPro <info@ecypro.com>"
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS already defined above for Mailpit

# ─── P55 IndexNow (Bing search engine ping) ─────────────────────────────────
# Register key at https://www.bing.com/indexnow and host the proof file
# at https://www.ecypro.com/<KEY>.txt
INDEXNOW_KEY=""
INDEXNOW_KEY_LOCATION="https://www.ecypro.com/INDEXNOW_KEY.txt"
INDEXNOW_HOST="www.ecypro.com"
INDEXNOW_SITEMAP_URL="https://www.ecypro.com/sitemap.xml"
INDEXNOW_ENABLED="0"

