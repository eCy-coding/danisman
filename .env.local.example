# EcyPro — Local Development Environment Template
# Kopyala: cp .env.local.example .env.local  (gitignored)

# --- Frontend (VITE_* prefix zorunlu) ---
VITE_API_URL=http://localhost:3001/api
VITE_EMAILJS_SERVICE_ID=mock_service
VITE_EMAILJS_TEMPLATE_ID=mock_template
VITE_EMAILJS_PUBLIC_KEY=mock_public_key
VITE_SENTRY_DSN=
VITE_GA_TRACKING_ID=

# --- Live Chat (opsiyonel — boş bırakılırsa devre dışı) ---
# Provider: crisp | tawk | intercom
VITE_LIVECHAT_PROVIDER=
VITE_LIVECHAT_ID=
# tawk.to widget id (sadece tawk kullanıyorsan)
VITE_LIVECHAT_TAWK_WIDGET_ID=

# --- Optional AI (Gemini) ---
GEMINI_API_KEY=PLACEHOLDER_API_KEY

# --- Backend server runtime ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
JWT_SECRET=change_me_local_only_minimum_32_chars_aaaaaa
JWT_EXPIRES_IN=7d
DATABASE_URL=postgresql://ecypro:ecypro@localhost:5432/ecypro?schema=public
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
SENTRY_DSN=
TRUST_PROXY=1

# --- Claude Code (opsiyonel — OAuth login alternatifi) ---
# Detay: docs/CLAUDE_CODE.md
ANTHROPIC_API_KEY=
