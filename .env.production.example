# =============================================================================
# eCyPro Premium Consulting — Production Environment Template
# COPY TO: .env.production  (gitignored)
# PHASE: 22 publish-readiness, Plan A (Hostinger static-only)
# =============================================================================
#
# IMPORTANT — All keys prefixed VITE_ are PUBLIC → bundled into client JS.
# Do NOT place server-only secrets among the VITE_ keys.
# Keys WITHOUT the VITE_ prefix (e.g. SENTRY_AUTH_TOKEN) are HOST-SHELL ONLY,
# consumed by release scripts (npm run release:sentry) and NEVER bundled.
#
# Required by P0-Step-4 fill-in checklist:
#   [ ] VITE_API_URL                  — A scenario: empty/blank ("") for simulation mode.
#   [ ] VITE_EMAILJS_SERVICE_ID       — REQUIRED — contact form will be inert without.
#   [ ] VITE_EMAILJS_TEMPLATE_ID      — REQUIRED
#   [ ] VITE_EMAILJS_PUBLIC_KEY       — REQUIRED (browser-safe public key, not user_id)
#   [ ] VITE_GA_TRACKING_ID           — REQUIRED — GA4 Measurement ID (G-XXXXXXXXXX)
#   [ ] VITE_SENTRY_DSN               — REQUIRED — front-end error reporting
#   [ ] VITE_GROWTHBOOK_CLIENT_KEY    — Optional — feature flags / A-B testing
#   [ ] VITE_GROWTHBOOK_API_HOST      — Optional — defaults to https://cdn.growthbook.io
#   [ ] VITE_LIVECHAT_PROVIDER        — Optional — 'crisp' | 'tawk' | 'intercom' | ''
#   [ ] VITE_LIVECHAT_ID              — Optional — provider account id
#   [ ] VITE_LIVECHAT_TAWK_WIDGET_ID  — Optional — only for tawk
#   [ ] SENTRY_AUTH_TOKEN             — HOST ONLY — for `npm run release:sentry`
#   [ ] SENTRY_ORG / SENTRY_PROJECT   — HOST ONLY — for `npm run release:sentry`
#
# =============================================================================

# --- API / Backend (Plan C hybrid is the active deployment scenario) ---
# Plan C (hybrid — Hostinger static + Render/Railway backend): point at the
# public api host. The frontend bundle calls https://api.ecypro.com/api/* and
# `scheduleHealthCheck` probes /api/health once after hydration in PROD.
# Plan A (static-only fallback): leave blank to enable simulation mode (the
# client falls back to in-memory adapters and silently no-ops the health check).
VITE_API_URL=https://api.ecypro.com/api

# --- Production canonical URL (used by sitemap, JSON-LD, smoke tests) ---
# Code references: import.meta.env.VITE_PROD_URL
VITE_PROD_URL=https://www.ecypro.com

# --- EmailJS (contact form — REQUIRED) ---
# Sign up at https://www.emailjs.com → create a service + template
# Template variables expected: from_name, from_email, message, to_name
VITE_EMAILJS_SERVICE_ID=__FILL_ME__
VITE_EMAILJS_TEMPLATE_ID=__FILL_ME__
VITE_EMAILJS_PUBLIC_KEY=__FILL_ME__

# --- Google Analytics 4 (REQUIRED) ---
# Format: G-XXXXXXXXXX (Measurement ID from GA4 → Admin → Data Streams)
VITE_GA_TRACKING_ID=__FILL_ME__

# --- Sentry front-end (REQUIRED for production error reporting) ---
# Format: https://<key>@<org>.ingest.sentry.io/<project>
VITE_SENTRY_DSN=__FILL_ME__

# --- GrowthBook (optional — feature flags / A-B testing) ---
# Code references: VITE_GROWTHBOOK_CLIENT_KEY + VITE_GROWTHBOOK_API_HOST
# Leave both blank to disable feature flag fetching at runtime.
VITE_GROWTHBOOK_CLIENT_KEY=
VITE_GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# --- Microsoft Clarity (optional — session recording / heatmaps) ---
# Format: project ID from clarity.microsoft.com
VITE_CLARITY_PROJECT_ID=

# --- Live chat (optional — set provider or leave blank) ---
# VITE_LIVECHAT_PROVIDER must be one of: '', 'crisp', 'tawk', 'intercom'
VITE_LIVECHAT_PROVIDER=
VITE_LIVECHAT_ID=
VITE_LIVECHAT_TAWK_WIDGET_ID=

# --- Telegram notification (optional, admin-only — opt-in for booking alerts) ---
# Leaving these blank is safe; only Admin/Booking flows reference them.
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# --- Build metadata (auto-filled by CI; safe defaults for manual deploys) ---
VITE_APP_VERSION=1.0.0
VITE_APP_BUILD_DATE=

# =============================================================================
# HOST-SHELL ONLY (NOT bundled into client JS — do NOT prefix with VITE_)
# Required by `npm run release:sentry` (scripts/upload-sourcemaps.mjs)
# =============================================================================

# Sentry release / sourcemap upload
SENTRY_AUTH_TOKEN=__FILL_ME__
SENTRY_ORG=__FILL_ME__
SENTRY_PROJECT=__FILL_ME__

# =============================================================================
# FILL-IN PROCEDURE (Plan A — Hostinger static):
#
# 1. cp .env.production.example .env.production
# 2. Open .env.production and replace every __FILL_ME__ with real values.
#    (SENTRY_* trio only needed if you intend to run `npm run release:sentry`.)
# 3. Verify with:
#      grep "__FILL_ME__" .env.production && echo "STILL HAS PLACEHOLDERS"
# 4. Run: npm run build
# 5. Inspect dist/index.html → no __FILL_ME__ string should appear.
# 6. Upload dist/ to Hostinger public_html.
# =============================================================================
