# =============================================================================
# eCyPro Premium Consulting — Production Environment Template
# COPY TO: .env.production  (gitignored)
# PHASE: P43 — merged HEAD (verbose checklist) + 70e4761 ship-prep (backend keys)
# =============================================================================
#
# IMPORTANT — All keys prefixed VITE_ are PUBLIC → bundled into client JS.
# Do NOT place server-only secrets among the VITE_ keys.
# Keys WITHOUT the VITE_ prefix (e.g. SENTRY_AUTH_TOKEN, DATABASE_URL) are
# HOST-SHELL / SERVER-ONLY, consumed by release scripts / Node runtime and
# NEVER bundled into the client.
#
# Fill-in checklist:
#   [ ] VITE_API_URL                  — backend host (Plan C hybrid)
#   [ ] VITE_EMAILJS_*                — only if legacy EmailJS path enabled
#   [ ] VITE_GA_TRACKING_ID           — REQUIRED — GA4 Measurement ID (G-XXXXXXXXXX)
#   [ ] VITE_SENTRY_DSN               — REQUIRED — front-end error reporting
#   [ ] VITE_GROWTHBOOK_CLIENT_KEY    — Optional — feature flags / A-B testing
#   [ ] SENTRY_AUTH_TOKEN             — HOST ONLY — for `npm run release:sentry`
#   [ ] SENTRY_ORG / SENTRY_PROJECT   — HOST ONLY
#   [ ] DATABASE_URL                  — backend Postgres
#   [ ] JWT_SECRET                    — backend auth
#   [ ] REDIS_URL                     — backend cache/queue
#   [ ] CORS_ORIGIN                   — backend CORS allowlist
#   [ ] SMTP_* (opsiyonel)            — backend transactional email
#
# =============================================================================

NODE_ENV=production

# --- Frontend / API ---
VITE_API_URL=https://api.ecypro.com/api
VITE_PROD_URL=https://www.ecypro.com
VITE_PUBLIC_URL=https://ecypro.com

# --- Database (backend) ---
DATABASE_URL=postgresql://user:password@host:5432/ecypro_prod

# --- Auth (backend) ---
JWT_SECRET=__GENERATE__openssl_rand_base64_32__
JWT_EXPIRES_IN=7d

# --- Cache / Queue (backend) ---
REDIS_URL=redis://redis-host:6379

# --- CORS (backend) ---
CORS_ORIGIN=https://ecypro.com,https://www.ecypro.com

# --- Sentry monitoring (frontend + backend) ---
# Front-end DSN format: https://<KEY>@o<ORG_ID>.ingest.sentry.io/<PROJECT_ID>
SENTRY_DSN=
SENTRY_RELEASE=
VITE_SENTRY_DSN=__FILL_ME__

# --- Analytics ---
# GA4 Measurement ID (G-XXXXXXXXXX) — required
VITE_GA_TRACKING_ID=__FILL_ME__
# Legacy alias kept for backward compat:
VITE_GA_ID=
VITE_META_PIXEL_ID=

# --- EmailJS (frontend — legacy, opsiyonel) ---
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Contact form / Telegram (backend only — moved out of VITE_* in P12) ---
# TELEGRAM_BOT_TOKEN ve TELEGRAM_CHAT_ID backend server/.env'a yazılır;
# frontend bundle artık embed etmiyor — /api/contact üzerinden proxy edilir.

# --- GrowthBook (feature flags — opsiyonel) ---
VITE_GROWTHBOOK_CLIENT_KEY=
VITE_GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# --- Microsoft Clarity (session recording — opsiyonel) ---
VITE_CLARITY_PROJECT_ID=

# --- Live chat (opsiyonel) ---
# Provider: '' | 'crisp' | 'tawk' | 'intercom'
VITE_LIVECHAT_PROVIDER=
VITE_LIVECHAT_ID=
VITE_LIVECHAT_TAWK_WIDGET_ID=

# --- Build metadata (auto-filled by CI; safe defaults for manual deploys) ---
VITE_APP_VERSION=1.0.0
VITE_APP_BUILD_DATE=

# --- SMTP (backend transactional email — opsiyonel) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=

# --- Rate limiting (backend; requests/minute) ---
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTH=10

# =============================================================================
# HOST-SHELL ONLY (NOT bundled into client JS — do NOT prefix with VITE_)
# Required by `npm run release:sentry` (scripts/upload-sourcemaps.mjs)
# =============================================================================
SENTRY_AUTH_TOKEN=__FILL_ME__
SENTRY_ORG=__FILL_ME__
SENTRY_PROJECT=__FILL_ME__

# =============================================================================
# FILL-IN PROCEDURE:
#
# 1. cp .env.production.example .env.production
# 2. Open .env.production and replace every __FILL_ME__ with real values.
# 3. Verify:
#      grep "__FILL_ME__" .env.production && echo "STILL HAS PLACEHOLDERS"
# 4. Run: npm run build
# 5. Inspect dist/index.html → no __FILL_ME__ string should appear.
# =============================================================================
