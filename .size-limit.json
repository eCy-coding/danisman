[
  {
    "name": "Initial JS (entry + critical chunks, brotli)",
    "path": [
      "dist/assets/main-*.js",
      "dist/assets/vendor-*.js",
      "dist/assets/lp.js"
    ],
    "limit": "120 KB",
    "brotli": true,
    "gzip": false
  },
  {
    "name": "Initial JS (gzip fallback)",
    "path": [
      "dist/assets/main-*.js",
      "dist/assets/vendor-*.js",
      "dist/assets/lp.js"
    ],
    "limit": "160 KB",
    "gzip": true
  },
  {
    "name": "Critical CSS (brotli)",
    "path": "dist/assets/*.css",
    "limit": "30 KB",
    "brotli": true
  },
  {
    "name": "Landing route + content chunk (brotli)",
    "path": [
      "dist/assets/lp.js",
      "dist/assets/lc.js"
    ],
    "limit": "80 KB",
    "brotli": true
  },
  {
    "name": "i18n chunk (brotli)",
    "path": "dist/assets/i18n-*.js",
    "limit": "25 KB",
    "brotli": true
  },
  {
    "name": "Motion chunk (brotli) — async route boundary",
    "path": "dist/assets/motion-*.js",
    "limit": "40 KB",
    "brotli": true
  },
  {
    "name": "Recharts chunk (brotli) — admin + ROI calculator",
    "path": "dist/assets/charts-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Sentry chunk (brotli)",
    "path": "dist/assets/sentry-*.js",
    "limit": "40 KB",
    "brotli": true
  },
  {
    "name": "Keystatic chunk (brotli) — admin-only, lazy",
    "path": "dist/assets/keystatic-*.js",
    "limit": "700 KB",
    "brotli": true,
    "ignore": []
  },
  {
    "name": "Service Worker (gzip)",
    "path": "dist/sw.js",
    "limit": "20 KB",
    "gzip": true
  }
]
