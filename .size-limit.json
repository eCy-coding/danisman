  },
  {
    "name": "Route: DataRightsPage (KVKK/GDPR form, brotli)",
    "path": "dist/assets/DataRightsPage-*.js",
    "limit": "30 KB",
    "brotli": true
  },
  {
    "name": "Route: PrivacyPage (brotli)",
    "path": "dist/assets/PrivacyPage-*.js",
    "limit": "30 KB",
