  },
  {
    "name": "Route: CookiePage (brotli)",
    "path": "dist/assets/CookiePage-*.js",
    "limit": "30 KB",
    "brotli": true
  },
  {
    "name": "Route: DashboardPage (admin, lazy, brotli)",
    "path": "dist/assets/DashboardPage-*.js",
    "limit": "100 KB",
    "brotli": true
  }
]
