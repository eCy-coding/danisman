[
  {
    "name": "Initial JS (entry + critical chunks, brotli)",
    "path": [
      "dist/assets/main-*.js",
      "dist/assets/vendor-*.js",
      "dist/assets/lp.js"
    ],
    "limit": "120 KB",
    "brotli": true,
    "gzip": false
  },
  {
    "name": "Initial JS (gzip fallback)",
    "path": [
      "dist/assets/main-*.js",
      "dist/assets/vendor-*.js",
      "dist/assets/lp.js"
    ],
    "limit": "160 KB",
    "gzip": true
  },
  {
    "name": "Critical CSS (brotli)",
    "path": "dist/assets/*.css",
    "limit": "30 KB",
    "brotli": true
  },
  {
    "name": "Landing route + content chunk (brotli)",
    "path": [
      "dist/assets/lp.js",
      "dist/assets/lc.js"
    ],
    "limit": "80 KB",
    "brotli": true
  },
  {
    "name": "i18n chunk (brotli)",
    "path": "dist/assets/i18n-*.js",
    "limit": "30 KB",
    "brotli": true
  },
  {
    "name": "Icons chunk (lucide-react, brotli)",
    "path": "dist/assets/icons-*.js",
    "limit": "30 KB",
    "brotli": true
  },
  {
    "name": "Motion chunk (brotli) — async route boundary",
    "path": "dist/assets/motion-*.js",
    "limit": "40 KB",
    "brotli": true
  },
  {
    "name": "Recharts chunk (brotli) — admin + ROI calculator",
    "path": "dist/assets/charts-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Sentry chunk (brotli)",
    "path": "dist/assets/sentry-*.js",
    "limit": "40 KB",
    "brotli": true
  },
  {
    "name": "Keystatic chunk (brotli) — admin-only, lazy",
    "path": "dist/assets/keystatic-*.js",
    "limit": "700 KB",
    "brotli": true,
    "ignore": []
  },
  {
    "name": "Service Worker (gzip)",
    "path": "dist/sw.js",
    "limit": "20 KB",
    "gzip": true
  },

  {
    "name": "Route: PricingPage (brotli)",
    "path": "dist/assets/PricingPage-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Route: ServicesPage (brotli)",
    "path": "dist/assets/ServicesPage-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Route: ServiceDetailPage (brotli)",
    "path": "dist/assets/ServiceDetailPage-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Route: AboutPage (brotli)",
    "path": "dist/assets/AboutPage-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Route: ContactPage (brotli)",
    "path": "dist/assets/ContactPage-*.js",
    "limit": "60 KB",
    "brotli": true
  },
  {
    "name": "Route: BlogPage (brotli)",
    "path": "dist/assets/BlogPage-*.js",
    "limit": "50 KB",
    "brotli": true
  },
  {
    "name": "Route: BlogPostPage (brotli)",
    "path": "dist/assets/BlogPostPage-*.js",
    "limit": "55 KB",
    "brotli": true
  },
  {
    "name": "Route: CaseStudiesPage (brotli)",
    "path": "dist/assets/CaseStudiesPage-*.js",
    "limit": "50 KB",
    "brotli": true
  },
  {
    "name": "Route: CaseStudyDetailPage (brotli)",
