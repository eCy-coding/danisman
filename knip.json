{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["index.html", "index.tsx", "App.tsx", "src/main.tsx", "src/App.tsx", "src/workers/director.worker.ts", "scripts/**/*.ts", "e2e/**/*.ts"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{ts,tsx}", "e2e/**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts", "src/vite-env.d.ts"],
  "ignoreDependencies": ["autoprefixer", "postcss", "tailwindcss", "eslint-plugin-react-refresh", "@types/node"],
  "ignoreExportsUsedInFile": true
}
