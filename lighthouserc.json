{
  "ci": {
    "collect": {
      "url": [
        "https://www.ecypro.com/",
        "https://www.ecypro.com/founder",
        "https://www.ecypro.com/pricing",
        "https://www.ecypro.com/discovery",
        "https://www.ecypro.com/services",
        "https://www.ecypro.com/perspektifler"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "_comment_thresholds": "S13-R7-C2 — tightened post-R3..R6 cascade: Perf 0.85→0.90, A11y 0.95→1.00 (axe gate already at 0 violations), BP 0.90→1.00, SEO 0.95→1.00. CWV LCP keeps 2500ms; CLS dropped 0.1→0.05 since R6-C1 App Shell h1 parity should kill the legacy shift. INP promoted from warn→error at 200ms (Google's CWV threshold).",
        "categories:performance": ["error", { "minScore": 0.90 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "interaction-to-next-paint": ["error", { "maxNumericValue": 200 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 500000 }],
        "uses-text-compression": "error",
        "uses-responsive-images": "warn",
        "unused-javascript": "warn",
        "uses-rel-preconnect": "warn",
        "render-blocking-resources": "warn",
        "csp-xss": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
