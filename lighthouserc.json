{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --port 4173",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/founder",
        "http://localhost:4173/pricing",
        "http://localhost:4173/discovery",
        "http://localhost:4173/services",
        "http://localhost:4173/perspektifler"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "assert": {
      "assertions": {
        "_comment_thresholds": "S14 R8/R9 — hybrid threshold (R5-R10 + #181 superseded): Perf 0.90 warn, A11y/SEO 1.0 error, BP 1.0 warn, LCP 2500ms warn, CLS 0.05 warn. R8 thresholds R8 already production-deployed (550542a+21ab8b7) — keep them as the source of truth.",
        "categories:performance": ["warn", { "minScore": 0.90 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["warn", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.05 }],
        "interaction-to-next-paint": ["warn", { "maxNumericValue": 200 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 500000 }],
        "uses-text-compression": "warn",
        "uses-responsive-images": "warn",
        "unused-javascript": "warn",
        "uses-rel-preconnect": "warn",
        "render-blocking-resources": "warn",
        "csp-xss": "warn",
        "non-composited-animations": "warn",
        "color-contrast": "warn",
        "target-size": "warn",
        "label-content-name-mismatch": "warn",
        "identical-links-same-purpose": "warn",
        "errors-in-console": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
