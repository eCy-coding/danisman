{
  "name": "copy-of-ecypro-premium-consulting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run server\" \"npm run terminal\"",
    "dev:server": "tsx server/index.ts",
    "server": "tsx server/index.ts",
    "terminal": "tsx server/terminal/server.ts",
    "gen:blog": "tsx scripts/generate-blog-index.ts",
    "gen:rss": "tsx scripts/generate-rss.ts",
    "gen:content": "tsx scripts/generate-content.ts",
    "build": "npm run gen:blog && vite build",
    "postbuild": "npx tsx scripts/generate-sitemap.ts && npx tsx scripts/generate-rss.ts",
    "preview": "vite preview --port 4173",
    "start:mock": "node server/mock-server.js",
    "e2e:local": "npm run start:mock & npm run preview & npm run test:e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "typecheck:web": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lh:audit": "tsx scripts/lighthouse.ts",
    "clean": "bash scripts/zero-waste.sh",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test sanity_check --reporter=list",
    "view": "tsx scripts/view-locally.ts",
    "build:wp": "npx tsx scripts/build-wp-theme.ts",
    "test": "vitest",
    "doc": "typedoc",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "deploy": "bash scripts/deploy.sh",
    "deploy:docker": "bash scripts/deploy.sh docker",
    "deploy:frontend": "bash scripts/deploy.sh frontend",
    "db:seed": "npx tsx scripts/seed.ts",
    "build:server": "npx tsc -p tsconfig.server.json",
    "claude:install": "bash scripts/install-claude-code.sh",
    "claude:doctor": "bash scripts/claude-doctor.sh",
    "claude:setup": "npm run claude:install && npm run claude:doctor",
    "claude:update": "claude --version && (claude update || npm install -g @anthropic-ai/claude-code)",
    "ollama": "bash scripts/ollama-launch.sh",
    "ollama:fast": "bash scripts/ollama-launch.sh -m qwen2.5-coder:14b -t code",
    "ollama:max": "bash scripts/ollama-launch.sh -m ecycode-orchestrator:latest -t orchestrate",
    "ollama:code": "bash scripts/ollama-launch.sh -m qwen2.5-coder:32b -t code",
    "ollama:math": "bash scripts/ollama-launch.sh -m ecycode-math:latest -t math",
    "ollama:gemma": "bash scripts/ollama-launch.sh -m gemma4:e2b -t code",
    "ollama:list": "bash scripts/ollama-launch.sh --list"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emailjs/browser": "^4.4.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@keystatic/core": "^0.5.48",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@sentry/node": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@sentry/react": "^10.51.0",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-table": "^8.21.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/marked": "^6.0.0",
    "@types/pg": "^8.20.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.555.0",
    "marked": "^17.0.1",
    "motion": "^12.23.26",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.2",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.69.0",
    "react-i18next": "^16.5.1",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.5.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "web-vitals": "^5.1.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.2",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "chalk": "^5.6.2",
    "chrome-launcher": "^1.2.1",
    "commander": "^14.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "execa": "^9.6.1",
    "globals": "^15.15.0",
    "husky": "^9.1.0",
    "inquirer": "^13.1.0",
    "jsdom": "^27.4.0",
    "lefthook": "^2.0.13",
    "lighthouse": "^13.0.1",
    "lint-staged": "^15.4.3",
    "openai": "^6.15.0",
    "ora": "^9.0.0",
    "pexels": "^1.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.2",
    "prisma": "^7.8.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "zx": "^8.8.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
