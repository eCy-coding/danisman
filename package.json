    "test:coverage": "vitest run --coverage",
    "test:server": "vitest --config vitest.server.config.ts --run",
    "test:all": "npm run test -- --run && npm run test:server",
    "doc": "typedoc",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:migrate:status": "npx prisma migrate status",
    "db:migrate:reset": "npx prisma migrate reset --skip-seed",
    "setup:env": "bash scripts/setup-env.sh",
    "deploy": "bash scripts/deploy.sh",
