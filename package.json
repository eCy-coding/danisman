    "backlinks:monitor": "npx tsx scripts/backlink-monitor.ts",
    "seo:weekly-diff": "npx tsx scripts/seo-weekly-diff.ts",
    "tunnel": "bash scripts/start-tunnel.sh",
    "setup": "bash scripts/setup-auto.sh",
    "health:check": "npx tsx scripts/service-health.ts",
    "test:urls": "npx playwright test e2e/crawl_url_integrity.spec.ts --project=chromium",
    "test:urls:all": "npx playwright test e2e/crawl_url_integrity.spec.ts --project=chromium --project=firefox --project=webkit",
    "crowler:content": "cd crowler && .venv/bin/python3 scripts/11_content_quality_audit.py --output json",
    "crowler:security": "cd crowler && .venv/bin/python3 scripts/12_security_headers_audit.py --output json",
    "test:crawl": "npx playwright test e2e/crawl_seo_audit.spec.ts e2e/crawl_link_integrity.spec.ts e2e/crawl_image_lcp.spec.ts e2e/crawl_content_quality.spec.ts e2e/crawl_schema_deep.spec.ts e2e/crawl_mobile_pwa.spec.ts e2e/crawl_performance_vitals.spec.ts e2e/crawl_security_headers.spec.ts e2e/crawl_conversion_funnel.spec.ts e2e/crawl_admin_rbac.spec.ts e2e/crawl_slash_commands.spec.ts e2e/crawl_booking_flow.spec.ts e2e/crawl_authority_seo.spec.ts e2e/crawl_i18n_international.spec.ts e2e/crawl_observability.spec.ts e2e/crawl_deployment_flow.spec.ts e2e/crawl_prompts_compliance.spec.ts e2e/crawl_python.spec.ts e2e/crawl_api_calibration.spec.ts e2e/crawl_mcp_live.spec.ts e2e/crawl_db_integration.spec.ts e2e/crawl_url_integrity.spec.ts --project=chromium"
