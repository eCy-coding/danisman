    "ollama:fast": "bash scripts/ollama-launch.sh -m qwen2.5-coder:14b -t code",
    "ollama:max": "bash scripts/ollama-launch.sh -m ecycode-orchestrator:latest -t orchestrate",
    "ollama:code": "bash scripts/ollama-launch.sh -m qwen2.5-coder:32b -t code",
    "ollama:math": "bash scripts/ollama-launch.sh -m ecycode-math:latest -t math",
    "ollama:gemma": "bash scripts/ollama-launch.sh -m gemma4:e2b -t code",
    "ollama:list": "bash scripts/ollama-launch.sh --list",
