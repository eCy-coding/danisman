    "crowler:keywords": "crowler/.venv/bin/python3 crowler/scripts/04_keyword_density_audit.py",
    "crowler:backlinks": "crowler/.venv/bin/python3 crowler/scripts/05_backlink_opportunity_finder.py",
    "crowler:index": "crowler/.venv/bin/python3 crowler/scripts/06_google_index_checker.py",
    "crowler:lcp": "crowler/.venv/bin/python3 crowler/scripts/07_lcp_image_audit.py",
    "crowler:graph": "crowler/.venv/bin/python3 crowler/scripts/08_internal_link_graph.py",
    "crowler:serp": "crowler/.venv/bin/python3 crowler/scripts/09_serp_rank_tracker.py",
