    "audit:jsonld": "npx tsx scripts/audit-jsonld.ts",
    "audit:seo": "npm run audit:canonical && npm run audit:jsonld",
    "seo:indexnow": "npx tsx scripts/indexnow-push.ts",
    "seo:index": "npx tsx scripts/indexing-api-push.ts",
    "seo:push": "npm run seo:indexnow && npm run seo:index",
    "audit:h1": "npx tsx scripts/audit-h1-keywords.ts",
    "audit:links": "npx tsx scripts/audit-internal-links.ts",
    "audit:all": "npm run audit:seo && npm run audit:h1 && npm run audit:links && npm run audit:img",
    "audit:img": "npx tsx scripts/audit-img-alt.ts",
    "funnel:report": "npx tsx scripts/funnel-report.ts",
    "funnel:report:30": "npx tsx scripts/funnel-report.ts --days=30",
    "lhci": "lhci autorun",
    "db:backup": "bash scripts/backup-db.sh",
    "gen:sitemap": "npx tsx scripts/generate-sitemap.ts",
