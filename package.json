{
  "name": "copy-of-ecypro-premium-consulting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run server\" \"npm run terminal\"",
    "dev:server": "tsx server/index.ts",
    "server": "tsx server/index.ts",
    "vite": "vite",
    "terminal": "tsx server/terminal/server.ts",
    "dev:tmux": "bash scripts/orchestrator.sh",
    "dev:up": "npm run dev:db && npm run dev:tmux",
    "dev:down": "tmux kill-session -t ecypro-dev 2>/dev/null; docker compose -f docker-compose.dev.yml down",
    "dev:reset": "npm run dev:down && docker compose -f docker-compose.dev.yml down -v && npm run dev:db && npx prisma db push",
    "dev:full": "concurrently -k -n FE,BE,SEO,MEDIA,GEO,CRM,SEC,LHCI,ANALYTICS -c blue,green,cyan,magenta,yellow,red,white,gray,brightCyan \"npm:vite\" \"npm:server\" \"npm:seo:watch\" \"npm:media:watch\" \"npm:geo:watch\" \"npm:crm:watch\" \"npm:sec:watch\" \"npm:lhci:watch\" \"npm:analytics:dev\"",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d postgres-dev redis-dev mailpit",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:db:logs": "docker compose -f docker-compose.dev.yml logs -f --tail=100",
    "dev:db:tools": "docker compose -f docker-compose.dev.yml --profile tools up -d adminer",
    "e2e:watch": "playwright test --ui",
    "seo:watch": "tsx scripts/seo-watch.ts",
    "media:watch": "tsx scripts/watch-media.ts",
    "geo:watch": "tsx scripts/geo-watch.ts",
    "crm:watch": "tsx scripts/crm-watch.ts",
    "sec:watch": "tsx scripts/sec-watch.ts",
    "deploy:watch": "tsx scripts/deploy-watch.ts",
    "analytics:dev": "tsx scripts/analytics-dev.ts",
    "lhci:watch": "tsx scripts/lhci-watch.ts",
    "logs:tail": "bash scripts/logs-tail.sh",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:install": "npm i -D @storybook/react @storybook/react-vite @storybook/addon-essentials @storybook/addon-a11y @storybook/addon-interactions storybook",
    "stories": "npm run storybook",
    "gen:blog": "tsx scripts/generate-blog-index.ts",
    "gen:rss": "tsx scripts/generate-rss.ts",
    "gen:content": "tsx scripts/generate-content.ts",
    "gen:og-image": "node scripts/generate-og-image.mjs",
    "release:sentry": "node scripts/upload-sourcemaps.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "qa:content": "node scripts/content-qa.mjs --check all",
    "qa:parity": "node scripts/content-qa.mjs --check parity",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "build": "npm run gen:blog && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "postbuild": "npx tsx scripts/generate-sitemap.ts && npx tsx scripts/generate-rss.ts && npm run gen:og-image",
    "preview": "vite preview --port 4173",
    "start:prod": "npm run build:all && pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs ecypro-api --lines 50",
    "start:mock": "node server/mock-server.js",
    "e2e:local": "npm run start:mock & npm run preview & npm run test:e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "typecheck:web": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lh:audit": "tsx scripts/lighthouse.ts",
    "clean": "bash scripts/zero-waste.sh",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test sanity_check --reporter=list",
    "view": "tsx scripts/view-locally.ts",
    "build:wp": "npx tsx scripts/build-wp-theme.ts",
