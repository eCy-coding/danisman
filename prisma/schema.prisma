// EcyPro Premium Consulting — Production Database Schema
// Prisma v7 + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  USER
  CLIENT
  CONSULTANT
  ADMIN
  PREMIUM
  // P62.B — Blog yazarı + içerik editörü rolleri (DB enum Neon production'a apply edildi 2026-05-18)
  BLOG_AUTHOR
  EDITOR
  // Phase 4 — RBAC Hardening: salt okunur rol
  VIEWER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum InteractionType {
  PAGE_VIEW
  CTA_CLICK
  FORM_SUBMIT
  BOOKING_START
  DOWNLOAD
  SCROLL_DEPTH
}

// ─── CORE MODELS ─────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String? // PBKDF2-SHA512 hash (format: salt:iterations:hash) — null for OAuth users
  name         String?
  avatarUrl    String?
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // P35-T03: Email verification
  emailVerified Boolean @default(false)

  // P35-T04: 2FA TOTP fields
  totpSecret  String? // encrypted TOTP secret (speakeasy base32)
  totpEnabled Boolean @default(false)
  backupCodes String? // JSON array of hashed backup codes

  // P14-BE: GDPR-aware soft-delete marker (hard-delete still available for
  // explicit Right-to-Erasure flow; default queries should filter this out).
  deletedAt DateTime?

  // Relations
  bookings           Booking[]
  interactions       Interaction[]
  analytics          Analytics[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  sessions           Session[] // P35-T09

  // NOTE: explicit @@index([email]) removed — `email` is already @unique
  // and Postgres auto-creates a btree index on UNIQUE columns. Keeping both
  // wastes write throughput and disk for zero read benefit.
  @@index([role])
  @@index([lastLoginAt])
  @@index([deletedAt])
  @@map("users")
}

// ─── BUSINESS MODELS ─────────────────────────────────────

model Service {
  id        String   @id @default(uuid())
  slug      String   @unique
  titleTr   String
  titleEn   String
  descTr    String
  descEn    String
  iconName  String   @default("Briefcase")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // P17 BE Track 2 / Aşama 3 — Postgres FTS support fields.
  //
  // Two `tsvector` columns are maintained by trigger (see migration
  // 20260516200000_p17_be_fts/migration.sql): one indexed with the
  // 'simple' dictionary so Turkish content is searchable without stemming
  // losses, the other with 'english' for the EN copy. Both are wrapped in
  // a GIN index for sub-ms `@@` lookups.
  //
  // The fields are declared `Unsupported` so the Prisma client still
  // produces typed accessors for the rest of Service, but doesn't try to
  // SELECT/INSERT the tsvector blob (Postgres generates it from the
  // trigger anyway).
  searchVectorTr Unsupported("tsvector")?
  searchVectorEn Unsupported("tsvector")?

  // Relations
  bookings Booking[]

  // NOTE: explicit @@index([slug]) removed — `slug` is already @unique.
  @@index([isActive, sortOrder])
  @@map("services")
}

model Booking {
  id                 String        @id @default(uuid())
  userId             String
  serviceId          String?
  status             BookingStatus @default(PENDING)
  scheduledAt        DateTime
  durationMin        Int           @default(30)
  notesTr            String?
  notesEn            String?
  meetingUrl         String?
  cancellationReason String?
  // P37-T01: Cal.com external booking UID (for webhook sync)
  calcomUid          String?       @unique
  // P37-T04: Reminder email idempotency flags
  reminder24hSent    Boolean       @default(false)
  reminder1hSent     Boolean       @default(false)
  // P37-T10: NPS feedback email sent flag
  feedbackEmailSent  Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  service  Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  feedback BookingFeedback?

  // P21-BE: explicit @@index([userId]) removed — leftmost-prefix of
  // @@index([userId, status, scheduledAt]) already covers it. See
  // outputs/P21_BE_INDEX_PROOF.md.
  // P21-BE: explicit @@index([status]) removed — leftmost-prefix of
  // @@index([status, scheduledAt, reminder24hSent]) already covers it.
  @@index([scheduledAt])
  // P14-BE: hot composite indexes for the reminder + NPS cron queries
  // (server/jobs/booking-reminders.ts). Without these, each scan is a
  // table-full filter on status + scheduledAt window + idempotency flag.
  @@index([status, scheduledAt, reminder24hSent])
  @@index([status, scheduledAt, reminder1hSent])
  @@index([status, scheduledAt, feedbackEmailSent])
  // Owner-scoped lookups ("my upcoming bookings")
  @@index([userId, status, scheduledAt])
  @@map("bookings")
}

// ─── ANALYTICS & TRACKING ────────────────────────────────

model Analytics {
  id         String   @id @default(uuid())
  userId     String?
  sessionId  String
  page       String
  referrer   String?
  userAgent  String?
  country    String?
  city       String?
  deviceType String? // desktop | mobile | tablet
  durationMs Int?
  createdAt  DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([page])
  @@index([createdAt])
  // P14-BE: dashboard "user activity over time" + date-range scans
  @@index([userId, createdAt])
  @@map("analytics")
}

model Interaction {
  id        String          @id @default(uuid())
  userId    String?
  sessionId String
  type      InteractionType
  target    String // e.g. "hero-cta", "contact-form"
  metadata  Json? // flexible payload
  createdAt DateTime        @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
  // P14-BE: dashboard "user funnel by type" + per-user behavioral cohort
  @@index([userId, type, createdAt])
  @@map("interactions")
}

// ─── CONTACT & LEADS ─────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  company   String?
  phone     String?
  service   String?
  messageTr String?
  messageEn String?
  source    String? // utm_source / referrer
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // P14-BE: GDPR soft-delete. Right-to-Erasure can either hard-delete the
  // row (legal default) or set deletedAt so an audit trail of "deletion"
  // remains for compliance proof. CRM list views filter on deletedAt IS NULL.
  deletedAt DateTime?

  @@index([email])
  // P21-BE: explicit @@index([isRead]) removed — leftmost-prefix of
  // @@index([isRead, createdAt]) already covers it.
  // Hot path: CRM inbox ordered "newest unread first"
  @@index([isRead, createdAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_submissions")
}

// ─── AUTH SECURITY (Phase 35) ────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  family    String // Rotation family — all revoked if reuse detected
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

// ─── ADMIN OPERATIONS (Phase 36) ─────────────────────────

// ─── USER SESSION TRACKING (P35-T09) ─────────────────────

model Session {
  id         String    @id @default(uuid())
  userId     String
  jti        String    @unique
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // P21-BE: explicit @@index([jti]) removed — `jti` is already @unique
  // (Postgres auto-creates a btree). See outputs/P21_BE_INDEX_PROOF.md.
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String // e.g. "USER_ROLE_CHANGE", "SETTING_UPDATE", "BOOKING_STATUS"
  targetType String? // e.g. "User", "Booking", "Service"
  targetId   String?
  oldValue   Json?
  newValue   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // P21-BE: explicit @@index([adminId]) removed — leftmost-prefix of
  // @@index([adminId, createdAt]) already covers it.
  @@index([action])
  @@index([createdAt])
  // P14-BE Track 2: "all audit events for resource X" — dashboard drill-down
  // (e.g. open a booking, see every admin action that touched it).
  @@index([targetType, targetId])
  // P14-BE Track 2: "what did admin Y do in the last N days" — required for
  // the admin-activity report; without this we degrade to a full scan over
  // audit_logs filtered in app code.
  @@index([adminId, createdAt])
  @@map("audit_logs")
}

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string | boolean | number | json
  label     String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  // P21-BE: explicit @@index([key]) removed — `key` is already @unique.
  @@map("site_configs")
}

// ─── P37-T10: POST-BOOKING NPS FEEDBACK ─────────────────
// Sent 1h after meeting end. Score 0-10 (NPS standard).
// Promoters (9-10), Passives (7-8), Detractors (0-6).
// NPS = %Promoters - %Detractors (range -100 to +100)
model BookingFeedback {
  id          String   @id @default(uuid())
  bookingId   String   @unique // one feedback per booking
  score       Int // 0-10 NPS score
  comment     String? // optional free-text
  submittedAt DateTime @default(now())
  token       String   @unique // HMAC token (single-use, 7d TTL)
  tokenUsed   Boolean  @default(false)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // P21-BE: explicit @@index([bookingId]) removed — `bookingId` is already @unique.
  @@index([submittedAt])
  @@map("booking_feedbacks")
}

// ─── NEWSLETTER ──────────────────────────────────────────
// Phase 20 (Phase 17 G2 closure): persist subscribers; in-memory Map removed.
// ─── P17 BE Track 2 / Aşama 5: WEBHOOK IDEMPOTENCY ───────
// External webhook receivers must be idempotent — a duplicate delivery
// (network retry, vendor replay) must NOT trigger the side-effect twice.
// We persist every inbound webhook by its `(source, externalId)` pair so
// the handler can upsert and skip cleanly on re-delivery.
//
// Storage strategy:
//   - One row per delivery. `processedAt` marks success.
//   - `payload` JSON keeps a forensic copy for ~30 days (cleaned by
//     cron `audit-log-cleanup` analogue once a retention sweep is added).
//   - `error` captures the last failure reason so the admin DLQ pane can
//     surface "things that arrived but never completed".
//
// Schema notes:
//   - `source` is a short string discriminator: "calcom", "stripe",
//     "telegram", etc. Don't index alone — composite with externalId.
//   - `(source, externalId)` is UNIQUE — that's the whole point of the
//     table. Anything that retries with the same pair upserts to the same row.
model WebhookEvent {
  id          String    @id @default(uuid())
  source      String
  externalId  String
  signature   String?
  payload     Json
  processedAt DateTime?
  error       String?
  receivedAt  DateTime  @default(now())

  @@unique([source, externalId], name: "WebhookEvent_source_externalId_unique")
  @@index([source, receivedAt])
  @@index([processedAt])
  @@map("webhook_events")
}

// ─── P23 BE Track 2 / Aşama 2: OUTBOUND WEBHOOK SUBSCRIPTIONS ──
// Partner-facing event push.
//
// `secret` is the shared HMAC key — never returned by GET endpoints once
// the subscription is created. Rotated via a dedicated endpoint that
// returns the new value once. `events` lists the event types the
// subscription wants delivered (e.g. ['user.created', 'booking.completed']).
//
// `failureCount` is consulted by the delivery worker: 10 consecutive
// failures auto-deactivates the subscription and emits an admin alert.
model WebhookSubscription {
  id           String    @id @default(cuid())
  userId       String
  url          String
  events       String[]
  secret       String
  active       Boolean   @default(true)
  failureCount Int       @default(0)
  lastSuccess  DateTime?
  lastFailure  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([active])
  @@map("webhook_subscriptions")
}

// ─── P23 BE Track 2 / Aşama 2: OUTBOUND WEBHOOK DELIVERIES ──
// One row per attempted delivery. Persisted (not Redis-only) so an
// operator can replay a delivery after the BullMQ retention window
// expires, and so the admin UI can show per-event history.
//
// `responseBodySnip` is truncated to 4 KB — full bodies live in cold
// storage if needed. Status transitions: pending → success | failed | dlq.
model WebhookDelivery {
  id               String    @id @default(cuid())
  subscriptionId   String
  eventType        String
  payload          Json
  status           String    @default("pending")
  attemptCount     Int       @default(0)
  lastAttemptAt    DateTime?
  responseStatus   Int?
  responseBodySnip String?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([status, createdAt])
  @@map("webhook_deliveries")
}

// ─── P17 BE Track 2 / Aşama 4: API KEYS ──────────────────
// Programmatic clients (3rd-party integrations, partner CRMs) authenticate
// via `Authorization: Bearer <key>`. We never store the raw key — only a
// SHA-256 hash so an exfil of the DB doesn't grant API access. The
// plaintext is only ever returned once at creation time.
//
// Scopes are simple string tags ("read:bookings", "write:contacts", …).
// The auth middleware reads them off the row and gates per-route.
model ApiKey {
  id         String    @id @default(uuid())
  // SHA-256 of the raw key. UNIQUE so a lookup is O(1) on the index.
  hashedKey  String    @unique
  // Operator-friendly label ("Cal.com integration", "Partner X import").
  name       String
  // Free-form scope tags. Convention: "<verb>:<resource>".
  scopes     String[]
  // Optional owner — admins create keys; some flows let a user create
  // their own. NULL when the key belongs to "the platform".
  userId     String?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("api_keys")
}

// ─── P18 BE Track 2 / Aşama 1: UPLOADED IMAGE METADATA ────
// One row per uploaded artifact. Storage-backend agnostic: `storageKey`
// is the opaque key the adapter understands ("<owner>/2026/05/<uuid>.webp")
// while `variants` records the AVIF/WebP/thumbnail derivatives created
// by the BullMQ image-resize worker.
//
// Why a dedicated table (not blob columns on User/BlogPost)?
//   - The same image can be referenced from many places (hero, OG image,
//     blog cover). Normalising avoids duplicate uploads.
//   - GDPR delete is simpler: cascade `images.ownerId = userId` → soft
//     archive job → object-storage purge.
//   - The hash column gives us cheap content-addressed dedupe.
model Image {
  id           String   @id @default(uuid())
  ownerId      String?
  storageKey   String   @unique
  contentType  String
  sizeBytes    Int
  width        Int?
  height       Int?
  // SHA-256 hex of the original bytes. UNIQUE because reuploading the
  // same file should return the existing row.
  hash         String   @unique
  // JSON map of variant-name → derivative metadata, e.g.
  //   { "webp": { "key": "...", "size": 1234 }, "thumb": {...} }
  variants     Json?
  status       String   @default("ready") // "ready" | "processing" | "failed"
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@map("images")
}

// ─── P18 BE Track 2 / Aşama 4: ARCHIVED AUDIT LOG METADATA ─
// Pointer table: when the weekly archival cron exports a window of
// `audit_logs` to cold storage as JSON.gz, this row keeps the bookkeeping
// (storage key, row range, byte count) so an operator can grep + restore.
// The hot `audit_logs` table is then DELETEd to keep its working set small.
model ArchivedAuditLog {
  id              String   @id @default(uuid())
  // Opaque storage adapter key, e.g. "audit-archive/2026/05/2026-05-01.json.gz".
  coldKey         String   @unique
  windowStart     DateTime
  windowEnd       DateTime
  rowsArchived    Int
  bytesCompressed Int
  archivedAt      DateTime @default(now())

  @@index([windowStart])
  @@index([windowEnd])
  @@index([archivedAt])
  @@map("archived_audit_logs")
}

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  consent        Boolean   @default(false)
  source         String? // utm_source / referrer / footer
  ip             String? // IPv4/v6 captured at signup (for abuse audit)
  userAgent      String?
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  // NOTE: explicit @@index([email]) removed — `email` is already @unique.
  @@index([subscribedAt])
  // P14-BE: "active subscribers only" exports filter on this constantly
  @@index([unsubscribedAt])
  @@map("newsletter_subscribers")
}

// ─── Cross-service partial-failure resilience: Outbox / WAL ─
// Write-Ahead Log for third-party integration side effects (Notion CRM,
// Resend autoresponder). A PENDING row is written BEFORE the outbound call;
// it transitions to COMPLETED on success or FAILED on error. A node-cron
// processor (server/jobs/process-outbox.ts) retries FAILED/PENDING rows and
// dead-letters (DLQ) after MAX_ATTEMPTS, alerting the operator via Telegram.
// payload holds only what's needed to replay the operation — never API tokens
// or full email bodies.
model IntegrationOutbox {
  id        String   @id @default(uuid())
  service   String // 'NOTION' | 'RESEND' | 'CALENDLY'
  operation String // 'upsertProspect' | 'sendAutoresponder' | …
  payload   Json // sanitized replay payload (no tokens / no email bodies)
  status    String   @default("PENDING") // PENDING | COMPLETED | FAILED | DLQ
  attempts  Int      @default(0)
  lastError String?  @db.Text
  traceId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, attempts])
  @@index([service, status])
  @@index([createdAt])
  @@map("integration_outbox")
}

// ─── P1 Phase 1: KVKK Consent Audit ─────────────────────────────────────────
// Immutable audit record of KVKK consent events (ROPA SAT-01 protocol).
// DB-level: application_user has no UPDATE/DELETE grants on this table.
// withdrawnAt is the ONLY mutable field (right-to-withdrawal, KVKK m.11).
model ConsentRecord {
  id          String    @id @default(cuid())
  leadId      String? // Notion page ID of the Aday
  consentType String // "KVKK_LEAD_FORM" | "KVKK_NEWSLETTER" | ...
  givenAt     DateTime  @default(now())
  ipAddress   String? // hashed or truncated (KVKK m.5 minimality)
  userAgent   String?
  formVersion String    @default("1.0.0") // bump when consent text changes → re-consent required
  withdrawnAt DateTime?

  @@index([leadId])
  @@index([consentType, givenAt])
  @@map("consent_records")
}

// ─── PHASE 2: REVENUE CORE ────────────────────────────────

enum DealType {
  SELL_SIDE
  BUY_SIDE
  DD_ONLY
  PMI
  ADVISORY
  OTHER
}

enum DealStage {
  DISCOVERY
  DD
  NEGOTIATION
  SPA_SIGNING
  CLOSING
  CLOSED_WON
  CLOSED_LOST
}

enum Currency {
  USD
  TRY
  EUR
}

enum RetainerStatus {
  ACTIVE
  PAUSED
  TERMINATED
}

enum MilestoneStatus {
  PENDING
  INVOICED
  PAID
  DELAYED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum WaveStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
}

enum ProspectStatus {
  SENT
  OPENED
  REPLIED
  MEETING
  DISQUALIFIED
}

// M&A deal / advisory process record.
// "Süreç" in TR brand voice — never "Deal" in UI.
model Deal {
  id                  String    @id @default(cuid())
  name                String
  type                DealType
  stage               DealStage @default(DISCOVERY)
  clientId            String?
  transactionValueUsd Decimal?
  successFeePct       Decimal   @default(0.02)
  successFeeUsd       Decimal?
  expectedCloseDate   DateTime?
  actualCloseDate     DateTime?
  closedLostReason    String?
  notes               String?
  ownerId             String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  milestones Milestone[]
  retainer   Retainer?

  @@index([stage])
  @@index([ownerId])
  @@index([expectedCloseDate])
  @@map("deals")
}

// Monthly advisory retainer.
// "Aylık Anlaşma" in TR brand voice — never "Retainer" in UI.
model Retainer {
  id            String         @id @default(cuid())
  dealId        String         @unique
  deal          Deal           @relation(fields: [dealId], references: [id])
  currency      Currency
  monthlyAmount Decimal
  kdvRate       Decimal        @default(0.20)
  stopajRate    Decimal        @default(0)
  startDate     DateTime
  endDate       DateTime?
  status        RetainerStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invoices Invoice[]

  @@index([status])
  @@map("retainers")
}

// Payment milestone tied to a deal (Avans %30 / Ara / Final %15).
model Milestone {
  id           String          @id @default(cuid())
  dealId       String
  deal         Deal            @relation(fields: [dealId], references: [id])
  name         String
  expectedDate DateTime?
  actualDate   DateTime?
  amountPct    Decimal
  amountUsd    Decimal?
  status       MilestoneStatus @default(PENDING)
  invoiceId    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([dealId, expectedDate])
  @@index([status])
  @@map("milestones")
}

// Invoice record for retainer monthly billing or milestone payments.
model Invoice {
  id            String        @id @default(cuid())
  retainerId    String?
  retainer      Retainer?     @relation(fields: [retainerId], references: [id])
  invoiceNumber String        @unique
  issuedAt      DateTime      @default(now())
  dueDate       DateTime
  paidAt        DateTime?
  subtotal      Decimal
  kdv           Decimal
  stopaj        Decimal
  total         Decimal
  currency      Currency
  status        InvoiceStatus @default(DRAFT)
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, dueDate])
  @@index([retainerId])
  @@map("invoices")
}

// Outreach wave — batch of prospects contacted in a campaign.
// "Dalga" in TR brand voice.
model OutreachWave {
  id                 String     @id @default(cuid())
  name               String
  status             WaveStatus @default(DRAFT)
  startDate          DateTime
  endDate            DateTime?
  targetRevenueUsd   Decimal?
  realizedRevenueUsd Decimal    @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  prospects OutreachProspect[]

  @@index([status])
  @@map("outreach_waves")
}

// Individual prospect within an outreach wave.
// "Aday" in TR brand voice — never "Lead" or "Prospect" in UI.
model OutreachProspect {
  id                String         @id @default(cuid())
  waveId            String
  wave              OutreachWave   @relation(fields: [waveId], references: [id])
  adayId            String?
  companyName       String
  contactName       String?
  contactEmail      String?
  contactRole       String?
  status            ProspectStatus @default(SENT)
  sentAt            DateTime?
  openedAt          DateTime?
  repliedAt         DateTime?
  estimatedValueUsd Decimal?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([waveId, status])
  @@index([status])
  @@map("outreach_prospects")
}

// ─── PHASE 3: KVKK COMPLIANCE SHIELD ────────────────────

enum DSARType {
  ACCESS
  RECTIFICATION
  ERASURE
  RESTRICTION
  PORTABILITY
  OBJECTION
  AUTOMATED_DECISION
}

enum DSARStatus {
  RECEIVED
  UNDER_REVIEW
  RESPONDED
  CLOSED
  REJECTED
}

enum BreachStatus {
  DETECTED
  INVESTIGATING
  REPORTED
  RESOLVED
}

enum ROPAStatus {
  ACTIVE
  DEPRECATED
  UNDER_REVIEW
}

// KVKK m.11 + GDPR Art.15-22 — Data Subject Access Request
// slaDeadline = receivedAt + 30d; extendable once (+30d) per KVKK m.13
model DSARRequest {
  id                        String           @id @default(cuid())
  requesterEmail            String
  requesterName             String
  requesterIdentityVerified Boolean          @default(false)
  requestType               DSARType
  description               String?
  receivedAt                DateTime         @default(now())
  slaDeadline               DateTime
  extendedOnce              Boolean          @default(false)
  status                    DSARStatus       @default(RECEIVED)
  assignedTo                String?
  respondedAt               DateTime?
  responseText              String?
  closureReason             String?
  auditLog                  DSARAuditEntry[]

  @@index([status, slaDeadline])
  @@index([requesterEmail])
  @@map("dsar_requests")
}

// Immutable audit trail — DB-level: no UPDATE/DELETE allowed (enforced via row-level trigger)
model DSARAuditEntry {
  id        String      @id @default(cuid())
  dsarId    String
  dsar      DSARRequest @relation(fields: [dsarId], references: [id])
  actorId   String
  action    String
  details   Json
  createdAt DateTime    @default(now())

  @@index([dsarId])
  @@index([actorId, createdAt])
  @@map("dsar_audit_entries")
}

// KVKK m.12/5 — 72-hour Kurul breach notification obligation
model BreachIncident {
  id                       String       @id @default(cuid())
  detectedAt               DateTime
  detectionSource          String
  description              String
  affectedDataCategories   String[]
  affectedSubjectsCount    Int
  notificationDeadline     DateTime
  reportedToKurul          Boolean      @default(false)
  reportedAt               DateTime?
  kurulFormDraft           String?
  affectedSubjectsNotified Boolean      @default(false)
  status                   BreachStatus @default(DETECTED)
  postMortemUrl            String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([status, notificationDeadline])
  @@map("breach_incidents")
}

// GDPR Art.30 + KVKK — Records of Processing Activities
// retentionPeriod is code-locked in src/constants/ropa-template.ts (01_NOTEBOOKLM_FINDINGS §2.7)
model ROPAProcess {
  id                   String     @id @default(cuid())
  processId            String     @unique
  name                 String
  purpose              String
  legalBasis           String
  dataCategories       String[]
  retentionPeriod      String
  retentionPeriodDays  Int
  retentionLegalSource String
  transferLocation     String
  transferMechanism    String?
  dpoApproved          Boolean    @default(false)
  lastReviewedAt       DateTime   @default(now())
  nextReviewDue        DateTime
  status               ROPAStatus @default(ACTIVE)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([status])
  @@index([processId])
  @@map("ropa_processes")
}

// Retention enforcement — nightly cron destroys data older than retentionDays + issues certificate
model RetentionPolicy {
  id            String    @id @default(cuid())
  resourceType  String    @unique
  retentionDays Int
  legalBasis    String
  lastEnforced  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("retention_policies")
}

// eCyPro-specific: Big4 conflict screen + Bağımsızlık Beyanı (yıllık)
model IndependenceCheck {
  id                    String   @id @default(cuid())
  clientId              String
  checkedAt             DateTime @default(now())
  auditFirmConflicts    String[]
  pureAdvisoryConfirmed Boolean
  signatoryUserId       String
  declarationDocUrl     String?
  validUntil            DateTime

  @@index([clientId])
  @@index([validUntil])
  @@map("independence_checks")
}

// ─── PHASE 4: RBAC HARDENING ─────────────────────────────
// Phase 4 — RBAC Hardening: runtime permission management

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique // e.g. "blog.create"
  resource        String // e.g. "blog"
  action          String // e.g. "create"
  description     String
  isSystem        Boolean          @default(true)
  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granted      Boolean    @default(false)
  grantedAt    DateTime   @default(now())
  grantedBy    String?

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

model RoleChangeAudit {
  id                  String   @id @default(cuid())
  actorId             String
  targetRole          UserRole
  targetPermissionKey String
  previousValue       Boolean
  newValue            Boolean
  reason              String?
  createdAt           DateTime @default(now())

  // KVKK m.12 immutable — application layer enforces no UPDATE/DELETE
  @@index([targetRole])
  @@index([createdAt])
  @@map("role_change_audit")
}

model ViewAsSession {
  id            String    @id @default(cuid())
  actorId       String
  viewingAsRole UserRole
  startedAt     DateTime  @default(now())
  endedAt       DateTime?

  @@index([actorId])
  @@index([startedAt])
  @@map("view_as_sessions")
}

// ─── PHASE 6: ENTERPRISE POLISH ──────────────────────────────

// Danışmanlık müşterisi — Succession/ESG/Fintech ilişkilerinde pivot
model Client {
  id           String   @id @default(cuid())
  name         String
  contactEmail String?
  sector       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  successionRoadmaps SuccessionRoadmap[]
  esgAssessments     ESGAssessment[]
  fintechItems       FintechComplianceItem[]

  @@index([isActive])
  @@map("clients")
}

// M1-A: Founder Letter — Emre Can Yalçın aylık bülten yönetimi
enum LetterStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model FounderLetter {
  id              String       @id @default(cuid())
  slug            String       @unique
  titleTr         String
  titleEn         String?
  contentMdTr     String       @db.Text
  contentMdEn     String?      @db.Text
  authorId        String
  status          LetterStatus @default(DRAFT)
  publishedAt     DateTime?
  scheduledFor    DateTime?
  emailSent       Boolean      @default(false)
  emailSentAt     DateTime?
  subscriberCount Int          @default(0)
  openRate        Decimal?
  clickRate       Decimal?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, publishedAt])
  @@map("founder_letters")
}

// M1-B: Succession Roadmap — aile şirketi kuşak geçişi
enum SuccessionStatus {
  ASSESSMENT
  PLANNING
  EXECUTION
  COMPLETED
}

enum SuccessionMilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

model SuccessionRoadmap {
  id             String           @id @default(cuid())
  clientId       String
  client         Client           @relation(fields: [clientId], references: [id])
  generationFrom Int
  generationTo   Int
  estimatedYear  Int?
  status         SuccessionStatus @default(ASSESSMENT)
  notes          String?          @db.Text
  ownerId        String

  milestones SuccessionMilestone[]
  kpis       SuccessionKPI[]

  @@index([clientId])
  @@index([status])
  @@map("succession_roadmaps")
}

model SuccessionMilestone {
  id           String                    @id @default(cuid())
  roadmapId    String
  roadmap      SuccessionRoadmap         @relation(fields: [roadmapId], references: [id])
  name         String
  expectedDate DateTime?
  actualDate   DateTime?
  status       SuccessionMilestoneStatus @default(PENDING)

  @@index([roadmapId])
  @@map("succession_milestones")
}

model SuccessionKPI {
  id            String            @id @default(cuid())
  roadmapId     String
  roadmap       SuccessionRoadmap @relation(fields: [roadmapId], references: [id])
  metric        String
  baselineValue String
  targetValue   String
  currentValue  String?
  measuredAt    DateTime?

  @@index([roadmapId])
  @@map("succession_kpis")
}

// M1-C: ESG / ESRS Data Architecture
enum ESGPillar {
  ENVIRONMENTAL
  SOCIAL
  GOVERNANCE
}

enum ESGStatus {
  GAP_ANALYSIS
  DATA_COLLECTION
  REVIEW
  PUBLISHED
}

model ESGDatapoint {
  id               String    @id @default(cuid())
  esrsCode         String    @unique // "E1-6-44", "S1-7-1", "G1-3-22"
  pillar           ESGPillar
  category         String
  topic            String
  metricName       String
  unit             String?
  isDoubleMaterial Boolean
  isMandatory      Boolean

  @@index([pillar])
  @@index([isMandatory])
  @@map("esg_datapoints")
}

model ESGAssessment {
  id                      String    @id @default(cuid())
  clientId                String
  client                  Client    @relation(fields: [clientId], references: [id])
  reportingYear           Int
  status                  ESGStatus @default(GAP_ANALYSIS)
  doubleMaterialityMatrix Json
  datapointValues         Json      @default("{}")
  completionPct           Decimal   @default(0)
  startedAt               DateTime  @default(now())
  publishedAt             DateTime?

  @@index([clientId])
  @@index([status])
  @@map("esg_assessments")
}

// M1-D: Fintech Compliance — SPK + MASAK + KVKK + TCMB + BDDK
enum Regulator {
  SPK
  MASAK
  KVKK
  TCMB
  BDDK
}

enum ComplianceItemStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model FintechComplianceItem {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id])
  regulator      Regulator
  category       String
  status         ComplianceItemStatus @default(NOT_STARTED)
  riskScore      Int
  dueDate        DateTime?
  lastReviewedAt DateTime?
  notes          String?

  @@index([clientId])
  @@index([regulator])
  @@index([status])
  @@map("fintech_compliance_items")
}

// M1-E: Local Data Residency — veri yerleşim rozeti
enum ResidencyLocation {
  TR_LOCAL
  EU_GDPR
  US_SCC
  OTHER
}

model DataResidencyTag {
  id                String            @id @default(cuid())
  resourceType      String
  resourceId        String
  location          ResidencyLocation
  transferMechanism String?
  documentedAt      DateTime          @default(now())

  @@index([resourceType, resourceId])
  @@index([location])
  @@map("data_residency_tags")
}
