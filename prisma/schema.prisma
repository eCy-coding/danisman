// EcyPro Premium Consulting — Production Database Schema
// Prisma v7 + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  USER
  CLIENT
  CONSULTANT
  ADMIN
  PREMIUM
  // P62.B — Blog yazarı + içerik editörü rolleri (DB enum Neon production'a apply edildi 2026-05-18)
  BLOG_AUTHOR
  EDITOR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum InteractionType {
  PAGE_VIEW
  CTA_CLICK
  FORM_SUBMIT
  BOOKING_START
  DOWNLOAD
  SCROLL_DEPTH
}

// ─── CORE MODELS ─────────────────────────────────────────

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String?       // PBKDF2-SHA512 hash (format: salt:iterations:hash) — null for OAuth users
  name         String?
  avatarUrl    String?
  role         UserRole      @default(USER)
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // P35-T03: Email verification
  emailVerified Boolean   @default(false)

  // P35-T04: 2FA TOTP fields
  totpSecret    String?   // encrypted TOTP secret (speakeasy base32)
  totpEnabled   Boolean   @default(false)
  backupCodes   String?   // JSON array of hashed backup codes

  // P14-BE: GDPR-aware soft-delete marker (hard-delete still available for
  // explicit Right-to-Erasure flow; default queries should filter this out).
  deletedAt     DateTime?

  // Relations
  bookings           Booking[]
  interactions       Interaction[]
  analytics          Analytics[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  sessions           Session[]           // P35-T09

  // NOTE: explicit @@index([email]) removed — `email` is already @unique
  // and Postgres auto-creates a btree index on UNIQUE columns. Keeping both
  // wastes write throughput and disk for zero read benefit.
  @@index([role])
  @@index([lastLoginAt])
  @@index([deletedAt])
  @@map("users")
}

// ─── BUSINESS MODELS ─────────────────────────────────────

model Service {
  id          String    @id @default(uuid())
  slug        String    @unique
  titleTr     String
  titleEn     String
  descTr      String
  descEn      String
  iconName    String    @default("Briefcase")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // P17 BE Track 2 / Aşama 3 — Postgres FTS support fields.
  //
  // Two `tsvector` columns are maintained by trigger (see migration
  // 20260516200000_p17_be_fts/migration.sql): one indexed with the
  // 'simple' dictionary so Turkish content is searchable without stemming
  // losses, the other with 'english' for the EN copy. Both are wrapped in
  // a GIN index for sub-ms `@@` lookups.
  //
  // The fields are declared `Unsupported` so the Prisma client still
  // produces typed accessors for the rest of Service, but doesn't try to
  // SELECT/INSERT the tsvector blob (Postgres generates it from the
  // trigger anyway).
  searchVectorTr Unsupported("tsvector")?
  searchVectorEn Unsupported("tsvector")?

  // Relations
  bookings    Booking[]

  // NOTE: explicit @@index([slug]) removed — `slug` is already @unique.
  @@index([isActive, sortOrder])
  @@map("services")
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  serviceId     String?
  status        BookingStatus @default(PENDING)
  scheduledAt   DateTime
  durationMin   Int           @default(30)
  notesTr       String?
  notesEn       String?
  meetingUrl    String?
  cancellationReason String?
  // P37-T01: Cal.com external booking UID (for webhook sync)
  calcomUid     String?   @unique
  // P37-T04: Reminder email idempotency flags
  reminder24hSent Boolean @default(false)
  reminder1hSent  Boolean @default(false)
  // P37-T10: NPS feedback email sent flag
  feedbackEmailSent Boolean @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  service       Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  feedback      BookingFeedback?

  // P21-BE: explicit @@index([userId]) removed — leftmost-prefix of
  // @@index([userId, status, scheduledAt]) already covers it. See
  // outputs/P21_BE_INDEX_PROOF.md.
  // P21-BE: explicit @@index([status]) removed — leftmost-prefix of
  // @@index([status, scheduledAt, reminder24hSent]) already covers it.
  @@index([scheduledAt])
  // P14-BE: hot composite indexes for the reminder + NPS cron queries
  // (server/jobs/booking-reminders.ts). Without these, each scan is a
  // table-full filter on status + scheduledAt window + idempotency flag.
  @@index([status, scheduledAt, reminder24hSent])
  @@index([status, scheduledAt, reminder1hSent])
  @@index([status, scheduledAt, feedbackEmailSent])
  // Owner-scoped lookups ("my upcoming bookings")
  @@index([userId, status, scheduledAt])
  @@map("bookings")
}

// ─── ANALYTICS & TRACKING ────────────────────────────────

model Analytics {
  id            String   @id @default(uuid())
  userId        String?
  sessionId     String
  page          String
  referrer      String?
  userAgent     String?
  country       String?
  city          String?
  deviceType    String?  // desktop | mobile | tablet
  durationMs    Int?
  createdAt     DateTime @default(now())

  // Relations
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([page])
  @@index([createdAt])
  // P14-BE: dashboard "user activity over time" + date-range scans
  @@index([userId, createdAt])
  @@map("analytics")
}

model Interaction {
  id            String          @id @default(uuid())
  userId        String?
  sessionId     String
  type          InteractionType
  target        String          // e.g. "hero-cta", "contact-form"
  metadata      Json?           // flexible payload
  createdAt     DateTime        @default(now())

  // Relations
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
  // P14-BE: dashboard "user funnel by type" + per-user behavioral cohort
  @@index([userId, type, createdAt])
  @@map("interactions")
}

// ─── CONTACT & LEADS ─────────────────────────────────────

model ContactSubmission {
  id          String   @id @default(uuid())
  fullName    String
  email       String
  company     String?
  phone       String?
  service     String?
  messageTr   String?
  messageEn   String?
  source      String?  // utm_source / referrer
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  // P14-BE: GDPR soft-delete. Right-to-Erasure can either hard-delete the
  // row (legal default) or set deletedAt so an audit trail of "deletion"
  // remains for compliance proof. CRM list views filter on deletedAt IS NULL.
  deletedAt   DateTime?

  @@index([email])
  // P21-BE: explicit @@index([isRead]) removed — leftmost-prefix of
  // @@index([isRead, createdAt]) already covers it.
  // Hot path: CRM inbox ordered "newest unread first"
  @@index([isRead, createdAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_submissions")
}

// ─── AUTH SECURITY (Phase 35) ────────────────────────────

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  family      String    // Rotation family — all revoked if reuse detected
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  ip          String?
  userAgent   String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerification {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

// ─── ADMIN OPERATIONS (Phase 36) ─────────────────────────

// ─── USER SESSION TRACKING (P35-T09) ─────────────────────

model Session {
  id          String    @id @default(uuid())
  userId      String
  jti         String    @unique
  userAgent   String?
  ip          String?
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  revokedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // P21-BE: explicit @@index([jti]) removed — `jti` is already @unique
  // (Postgres auto-creates a btree). See outputs/P21_BE_INDEX_PROOF.md.
  @@map("sessions")
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String   // e.g. "USER_ROLE_CHANGE", "SETTING_UPDATE", "BOOKING_STATUS"
  targetType  String?  // e.g. "User", "Booking", "Service"
  targetId    String?
  oldValue    Json?
  newValue    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  // P21-BE: explicit @@index([adminId]) removed — leftmost-prefix of
  // @@index([adminId, createdAt]) already covers it.
  @@index([action])
  @@index([createdAt])
  // P14-BE Track 2: "all audit events for resource X" — dashboard drill-down
  // (e.g. open a booking, see every admin action that touched it).
  @@index([targetType, targetId])
  // P14-BE Track 2: "what did admin Y do in the last N days" — required for
  // the admin-activity report; without this we degrade to a full scan over
  // audit_logs filtered in app code.
  @@index([adminId, createdAt])
  @@map("audit_logs")
}

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string | boolean | number | json
  label     String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  // P21-BE: explicit @@index([key]) removed — `key` is already @unique.
  @@map("site_configs")
}

// ─── P37-T10: POST-BOOKING NPS FEEDBACK ─────────────────
// Sent 1h after meeting end. Score 0-10 (NPS standard).
// Promoters (9-10), Passives (7-8), Detractors (0-6).
// NPS = %Promoters - %Detractors (range -100 to +100)
model BookingFeedback {
  id          String   @id @default(uuid())
  bookingId   String   @unique   // one feedback per booking
  score       Int                // 0-10 NPS score
  comment     String?            // optional free-text
  submittedAt DateTime @default(now())
  token       String   @unique   // HMAC token (single-use, 7d TTL)
  tokenUsed   Boolean  @default(false)

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // P21-BE: explicit @@index([bookingId]) removed — `bookingId` is already @unique.
  @@index([submittedAt])
  @@map("booking_feedbacks")
}

// ─── NEWSLETTER ──────────────────────────────────────────
// Phase 20 (Phase 17 G2 closure): persist subscribers; in-memory Map removed.
// ─── P17 BE Track 2 / Aşama 5: WEBHOOK IDEMPOTENCY ───────
// External webhook receivers must be idempotent — a duplicate delivery
// (network retry, vendor replay) must NOT trigger the side-effect twice.
// We persist every inbound webhook by its `(source, externalId)` pair so
// the handler can upsert and skip cleanly on re-delivery.
//
// Storage strategy:
//   - One row per delivery. `processedAt` marks success.
//   - `payload` JSON keeps a forensic copy for ~30 days (cleaned by
//     cron `audit-log-cleanup` analogue once a retention sweep is added).
//   - `error` captures the last failure reason so the admin DLQ pane can
//     surface "things that arrived but never completed".
//
// Schema notes:
//   - `source` is a short string discriminator: "calcom", "stripe",
//     "telegram", etc. Don't index alone — composite with externalId.
//   - `(source, externalId)` is UNIQUE — that's the whole point of the
//     table. Anything that retries with the same pair upserts to the same row.
model WebhookEvent {
  id          String    @id @default(uuid())
  source      String
  externalId  String
  signature   String?
  payload     Json
  processedAt DateTime?
  error       String?
  receivedAt  DateTime  @default(now())

  @@unique([source, externalId], name: "WebhookEvent_source_externalId_unique")
  @@index([source, receivedAt])
  @@index([processedAt])
  @@map("webhook_events")
}

// ─── P23 BE Track 2 / Aşama 2: OUTBOUND WEBHOOK SUBSCRIPTIONS ──
// Partner-facing event push.
//
// `secret` is the shared HMAC key — never returned by GET endpoints once
// the subscription is created. Rotated via a dedicated endpoint that
// returns the new value once. `events` lists the event types the
// subscription wants delivered (e.g. ['user.created', 'booking.completed']).
//
// `failureCount` is consulted by the delivery worker: 10 consecutive
// failures auto-deactivates the subscription and emits an admin alert.
model WebhookSubscription {
  id           String    @id @default(cuid())
  userId       String
  url          String
  events       String[]
  secret       String
  active       Boolean   @default(true)
  failureCount Int       @default(0)
  lastSuccess  DateTime?
  lastFailure  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([active])
  @@map("webhook_subscriptions")
}

// ─── P23 BE Track 2 / Aşama 2: OUTBOUND WEBHOOK DELIVERIES ──
// One row per attempted delivery. Persisted (not Redis-only) so an
// operator can replay a delivery after the BullMQ retention window
// expires, and so the admin UI can show per-event history.
//
// `responseBodySnip` is truncated to 4 KB — full bodies live in cold
// storage if needed. Status transitions: pending → success | failed | dlq.
model WebhookDelivery {
  id               String    @id @default(cuid())
  subscriptionId   String
  eventType        String
  payload          Json
  status           String    @default("pending")
  attemptCount     Int       @default(0)
  lastAttemptAt    DateTime?
  responseStatus   Int?
  responseBodySnip String?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([status, createdAt])
  @@map("webhook_deliveries")
}

// ─── P17 BE Track 2 / Aşama 4: API KEYS ──────────────────
// Programmatic clients (3rd-party integrations, partner CRMs) authenticate
// via `Authorization: Bearer <key>`. We never store the raw key — only a
// SHA-256 hash so an exfil of the DB doesn't grant API access. The
// plaintext is only ever returned once at creation time.
//
// Scopes are simple string tags ("read:bookings", "write:contacts", …).
// The auth middleware reads them off the row and gates per-route.
model ApiKey {
  id          String    @id @default(uuid())
  // SHA-256 of the raw key. UNIQUE so a lookup is O(1) on the index.
  hashedKey   String    @unique
  // Operator-friendly label ("Cal.com integration", "Partner X import").
  name        String
  // Free-form scope tags. Convention: "<verb>:<resource>".
  scopes      String[]
  // Optional owner — admins create keys; some flows let a user create
  // their own. NULL when the key belongs to "the platform".
  userId      String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("api_keys")
}

// ─── P18 BE Track 2 / Aşama 1: UPLOADED IMAGE METADATA ────
// One row per uploaded artifact. Storage-backend agnostic: `storageKey`
// is the opaque key the adapter understands ("<owner>/2026/05/<uuid>.webp")
// while `variants` records the AVIF/WebP/thumbnail derivatives created
// by the BullMQ image-resize worker.
//
// Why a dedicated table (not blob columns on User/BlogPost)?
//   - The same image can be referenced from many places (hero, OG image,
//     blog cover). Normalising avoids duplicate uploads.
//   - GDPR delete is simpler: cascade `images.ownerId = userId` → soft
//     archive job → object-storage purge.
//   - The hash column gives us cheap content-addressed dedupe.
model Image {
  id           String   @id @default(uuid())
  ownerId      String?
  storageKey   String   @unique
  contentType  String
  sizeBytes    Int
  width        Int?
  height       Int?
  // SHA-256 hex of the original bytes. UNIQUE because reuploading the
  // same file should return the existing row.
  hash         String   @unique
  // JSON map of variant-name → derivative metadata, e.g.
  //   { "webp": { "key": "...", "size": 1234 }, "thumb": {...} }
  variants     Json?
  status       String   @default("ready") // "ready" | "processing" | "failed"
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@map("images")
}

// ─── P18 BE Track 2 / Aşama 4: ARCHIVED AUDIT LOG METADATA ─
// Pointer table: when the weekly archival cron exports a window of
// `audit_logs` to cold storage as JSON.gz, this row keeps the bookkeeping
// (storage key, row range, byte count) so an operator can grep + restore.
// The hot `audit_logs` table is then DELETEd to keep its working set small.
model ArchivedAuditLog {
  id             String   @id @default(uuid())
  // Opaque storage adapter key, e.g. "audit-archive/2026/05/2026-05-01.json.gz".
  coldKey        String   @unique
  windowStart    DateTime
  windowEnd      DateTime
  rowsArchived   Int
  bytesCompressed Int
  archivedAt     DateTime @default(now())

  @@index([windowStart])
  @@index([windowEnd])
  @@index([archivedAt])
  @@map("archived_audit_logs")
}

model NewsletterSubscriber {
  id              String    @id @default(uuid())
  email           String    @unique
  consent         Boolean   @default(false)
  source          String?   // utm_source / referrer / footer
  ip              String?   // IPv4/v6 captured at signup (for abuse audit)
  userAgent       String?
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?

  // NOTE: explicit @@index([email]) removed — `email` is already @unique.
  @@index([subscribedAt])
  // P14-BE: "active subscribers only" exports filter on this constantly
  @@index([unsubscribedAt])
  @@map("newsletter_subscribers")
}

// ─── Cross-service partial-failure resilience: Outbox / WAL ─
// Write-Ahead Log for third-party integration side effects (Notion CRM,
// Resend autoresponder). A PENDING row is written BEFORE the outbound call;
// it transitions to COMPLETED on success or FAILED on error. A node-cron
// processor (server/jobs/process-outbox.ts) retries FAILED/PENDING rows and
// dead-letters (DLQ) after MAX_ATTEMPTS, alerting the operator via Telegram.
// payload holds only what's needed to replay the operation — never API tokens
// or full email bodies.
model IntegrationOutbox {
  id        String   @id @default(uuid())
  service   String // 'NOTION' | 'RESEND' | 'CALENDLY'
  operation String // 'upsertProspect' | 'sendAutoresponder' | …
  payload   Json // sanitized replay payload (no tokens / no email bodies)
  status    String   @default("PENDING") // PENDING | COMPLETED | FAILED | DLQ
  attempts  Int      @default(0)
  lastError String?  @db.Text
  traceId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, attempts])
  @@index([service, status])
  @@index([createdAt])
  @@map("integration_outbox")
}

// ─── P1 Phase 1: KVKK Consent Audit ─────────────────────────────────────────
// Immutable audit record of KVKK consent events (ROPA SAT-01 protocol).
// DB-level: application_user has no UPDATE/DELETE grants on this table.
// withdrawnAt is the ONLY mutable field (right-to-withdrawal, KVKK m.11).
model ConsentRecord {
  id          String    @id @default(cuid())
  leadId      String?   // Notion page ID of the Aday
  consentType String    // "KVKK_LEAD_FORM" | "KVKK_NEWSLETTER" | ...
  givenAt     DateTime  @default(now())
  ipAddress   String?   // hashed or truncated (KVKK m.5 minimality)
  userAgent   String?
  formVersion String    @default("1.0.0") // bump when consent text changes → re-consent required
  withdrawnAt DateTime?

  @@index([leadId])
  @@index([consentType, givenAt])
  @@map("consent_records")
}

